{% set backbone = data.TopologyMplsBackbone.edges[0].node %}
{# `labbed_pes` (the lab-deployable PE nodes) is supplied by the transform so
   the "which PEs are lab-deployable" rule lives in one place — see
   transforms/clab_topology.py:_labbed_pes. #}
{# Translate an Infrahub interface name (e.g. "Ethernet4") to the form clab
   needs for the link endpoint, based on the container kind.
   - ceos: data ports are eth1, eth2, ... (clab maps eth<N> ↔ Ethernet<N>)
   - srl:  data ports must match ethernet-L/P (we use line card 1)
   - other kinds (linux): pass the name through. #}
{% macro clab_iface(name, kind) -%}
{%- set port = name | replace('Ethernet', '') -%}
{%- if kind == 'ceos' -%}eth{{ port }}
{%- elif kind == 'srl' -%}ethernet-1/{{ port }}
{%- else -%}{{ name }}
{%- endif -%}
{% endmacro %}
# Containerlab topology for the {{ backbone.name.value }} backbone.
# Only PEs whose platform has containerlab_os set are included.
# Nokia SR OS is substituted to SR Linux (`srl`) because the lab uses
# the publicly available SR Linux image; the per-PE config artifact
# still renders SR OS canon for the engineer audience.
---
name: {{ backbone.name.value }}

# Pin the management bridge to a subnet that doesn't overlap the
# sp-demo Infrahub compose network (172.20.0.0/16). Containerlab's
# default 172.20.20.0/24 sits inside that range and Docker refuses
# to create the bridge.
mgmt:
  network: clab-{{ backbone.name.value }}
  ipv4-subnet: 172.100.20.0/24
  ipv6-subnet: 3fff:172:100:20::/64

topology:
  defaults:
    env:
      LAB_NAME: {{ backbone.name.value }}

  kinds:
    ceos:
      # OpsMill-hosted public mirror; the upstream Arista cEOS image
      # is gated by login. Matches the image used by infrahub-demo-dc.
      image: registry.opsmill.io/external/ceos-image:4.29.0.2F
    srl:
      image: ghcr.io/nokia/srlinux:23.10
    linux:
      image: nicolaka/netshoot:latest

  nodes:
{% for pe in labbed_pes %}
    {{ pe.name.value }}:
      kind: {{ pe.platform.node.containerlab_os.value }}
      startup-config: devices/{{ pe.name.value }}.cfg
{% endfor %}
{# Skip sites whose generator hasn't materialized PE/CE addresses or interfaces yet. #}
{% set materialized_sites = data.ServiceL3VpnSite.edges
    | selectattr('node.pe_interface.node')
    | selectattr('node.pe_address.node')
    | selectattr('node.ce_address.node')
    | list %}
{% for site_edge in materialized_sites %}
{% set site = site_edge.node %}
{% set pe_platform = site.pe_device.node.platform.node.name.value %}
{% if pe_platform in ['arista_eos', 'nokia_sros'] %}
    ce-{{ site.l3vpn.node.name.value }}-{{ site.pe_device.node.name.value }}:
      kind: linux
      exec:
        - ip addr add {{ site.ce_address.node.address.value }} dev eth1
        # 'replace' instead of 'add' — the container already has a default
        # route via the clab management bridge (eth0) at startup; 'add'
        # errors with RTNETLINK File exists. 'replace' is idempotent.
        - ip route replace default via {{ site.pe_address.node.address.value.split('/')[0] }}
{% endif %}
{% endfor %}

  links:
{# Backbone p2p links, derived in the transform by pairing the core
   interfaces of lab-deployable PEs that share a /31. Renders every backbone
   link whose two endpoints are both lab-deployable (all of them when the
   backbone is single-vendor cEOS; only the Arista↔Nokia link in the mixed
   ISP dataset). #}
{% for link in backbone_links %}
    - endpoints: ["{{ link.endpoints[0].device }}:{{ clab_iface(link.endpoints[0].iface, link.endpoints[0].kind) }}", "{{ link.endpoints[1].device }}:{{ clab_iface(link.endpoints[1].iface, link.endpoints[1].kind) }}"]
{% endfor %}
{% for site_edge in materialized_sites %}
{% set site = site_edge.node %}
{% set pe_platform = site.pe_device.node.platform.node.name.value %}
{% set pe_kind = site.pe_device.node.platform.node.containerlab_os.value %}
{% if pe_platform in ['arista_eos', 'nokia_sros'] %}
    - endpoints:
        - "{{ site.pe_device.node.name.value }}:{{ clab_iface(site.pe_interface.node.name.value, pe_kind) }}"
        - "ce-{{ site.l3vpn.node.name.value }}-{{ site.pe_device.node.name.value }}:eth1"
{% endif %}
{% endfor %}
